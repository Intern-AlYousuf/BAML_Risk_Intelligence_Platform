# ══════════════════════════════════════════════════════════════════════════════
#  BAML Risk Intelligence Platform — Environment Configuration Reference
#  ─────────────────────────────────────────────────────────────────────
#  HOW TO USE THIS FILE
#  1. Copy to .env:    cp .env.example .env
#  2. Fill in every line marked  ← REQUIRED
#  3. Review every line marked   ← CHANGE FOR PRODUCTION
#  4. Never commit .env to version control  (.gitignore already covers it)
#
#  RESOLUTION ORDER  (highest priority wins)
#  ┌─────────────────────────────────────────────────────┐
#  │  1. Shell / Docker / Railway environment variables  │
#  │  2. Values in this .env file                        │
#  │  3. Defaults defined in app/core/config.py          │
#  └─────────────────────────────────────────────────────┘
#
#  DEPLOYMENT QUICK-REFERENCE
#  ┌──────────────────┬─────────────────────────────────────────────────────┐
#  │ Local dev        │ Fill POSTGRES_* section (Option B). Leave the rest. │
#  │ Docker Compose   │ Set POSTGRES_HOST=db (matches service name).        │
#  │ Railway          │ DATABASE_URL and PORT are injected automatically.   │
#  │ Production       │ See the Production Checklist at the bottom.         │
#  └──────────────────┴─────────────────────────────────────────────────────┘
# ══════════════════════════════════════════════════════════════════════════════


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  APPLICATION METADATA
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Human-readable platform name — appears in API responses and log lines.
APP_NAME="BAML Risk Intelligence Platform"

# Runtime environment.  Controls: docs exposure, log format, production guards.
# Accepted values: development | staging | production
# ← CHANGE FOR PRODUCTION
APP_ENV=development

# Semantic version — surfaced by GET /health/live and OpenAPI metadata.
APP_VERSION=1.0.0

# Enable verbose error output and SQL query logging.
# Must be false in production (enforced by config.py at startup).
# ← CHANGE FOR PRODUCTION
DEBUG=true


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SERVER
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Bind address for uvicorn.  0.0.0.0 exposes all interfaces (required in Docker).
HOST=0.0.0.0

# HTTP port.
# Railway overrides this automatically — do not hard-code in production.
# Local default: 8000
PORT=8000


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Versioned API path prefix.  All domain routes are mounted under this prefix.
# Do not change unless you are introducing a breaking v2 API surface.
API_V1_PREFIX=/api/v1

# HMAC-SHA256 signing key for JWT access tokens.
# ← REQUIRED  |  ← CHANGE FOR PRODUCTION
#
# Generate a secure value:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Requirements (enforced at startup in production):
#   - Must not equal the placeholder below
#   - Must be at least 32 characters
#   - Treat as a password — never log, expose in responses, or commit
SECRET_KEY=CHANGE_THIS_TO_A_CRYPTOGRAPHICALLY_SECURE_RANDOM_STRING

# JWT access token lifetime in minutes.
# 60 min is suitable for interactive sessions.
# Reduce to 15 min for high-security institutional environments.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Maximum time (seconds) the API will wait for an upstream response
# before returning 504 Gateway Timeout.
API_REQUEST_TIMEOUT_SECONDS=30


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DATABASE
#
#  Choose ONE option.  Do not set both.
#
#  Option A — Direct URL  (Railway, Heroku, managed cloud)
#  ─────────────────────────────────────────────────────────────────────────────
#  Railway injects DATABASE_URL automatically.  You only need to set this
#  manually for other platforms that provide a single connection string.
#  The app normalises postgresql:// and postgres:// to postgresql+asyncpg://
#  automatically — you do not need to change the scheme.
#
#  Option B — Individual components  (Docker Compose, local dev)
#  ─────────────────────────────────────────────────────────────────────────────
#  When DATABASE_URL is absent the app assembles the connection string from
#  the POSTGRES_* variables below.  Use this path for local development and
#  Docker Compose where you control the individual credentials.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Option A: Single connection string ───────────────────────────────────────
# Uncomment and fill in for Railway / Heroku / cloud-managed PostgreSQL.
# Leave commented when using Option B below.
#
# DATABASE_URL=postgresql://your-user:your-password@your-host:5432/your-db

# ── Option B: Individual components ──────────────────────────────────────────
# ← REQUIRED for local / Docker deployments when DATABASE_URL is not set.

# Database superuser for this application.  Create with:
#   CREATE USER baml_user WITH PASSWORD 'your-password';
#   GRANT ALL PRIVILEGES ON DATABASE baml_risk_db TO baml_user;
POSTGRES_USER=baml_user

# ← REQUIRED  |  ← CHANGE FOR PRODUCTION
# Use a strong random password in all non-development environments.
POSTGRES_PASSWORD=baml_password

# Hostname of the PostgreSQL server.
# Local dev:      localhost
# Docker Compose: db    (matches the service name in docker-compose.yml)
# Managed cloud:  your-host.rds.amazonaws.com  (or equivalent)
POSTGRES_HOST=localhost

# PostgreSQL port.  Default is 5432; change only if your instance differs.
POSTGRES_PORT=5432

# Database name.  Created with:
#   CREATE DATABASE baml_risk_db OWNER baml_user;
POSTGRES_DB=baml_risk_db

# ── Connection pool tuning ────────────────────────────────────────────────────
# Pool size formula:  DB_POOL_SIZE = (num_workers × 2) + 1  is a common heuristic.
# For Railway Hobby tier (shared PG, max 25 connections):
#   DB_POOL_SIZE=5  DB_MAX_OVERFLOW=5
# For Railway Pro / dedicated PG (max 100+ connections):
#   DB_POOL_SIZE=10  DB_MAX_OVERFLOW=20
#
# DB_ECHO=true enables per-statement SQL logging — dev only, never in production.

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  REDIS  (optional — phase 2)
#
#  Required for:  in-memory rate limiting, response caching, async task queues.
#  Not required for the initial deployment — leave commented until needed.
#
#  Formats accepted:
#    redis://localhost:6379/0
#    redis://:password@host:6379/0        (with password)
#    rediss://host:6380/0                 (TLS — use for Railway Redis)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# REDIS_URL=redis://localhost:6379/0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  CORS  (Cross-Origin Resource Sharing)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Comma-separated list of browser origins allowed to call the API.
# These are enforced by CORSMiddleware on every preflight and actual request.
#
# Local dev:    http://localhost:3000,http://localhost:5173
# Staging:      https://staging.baml-risk.example.com
# Production:   https://baml-risk.example.com
#               (no trailing slash, no wildcard unless explicitly intended)
#
# ← CHANGE FOR PRODUCTION
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Comma-separated list of valid Host header values (TrustedHostMiddleware).
# "*" accepts any Host and is appropriate only for local development.
# Production requires explicit hostnames — config.py rejects "*" when
# APP_ENV=production.
#
# ← CHANGE FOR PRODUCTION  (example: api.baml-risk.example.com)
ALLOWED_HOSTS=*


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SECURITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# bcrypt work factor for password hashing.
# Each increment roughly doubles hash time.
# Recommended values:
#   Development:  10  (fast test cycles)
#   Staging:      12  (default — ~300 ms on modern hardware)
#   Production:   13  (≈600 ms — OWASP 2023 recommendation)
#
# ← CHANGE FOR PRODUCTION
BCRYPT_ROUNDS=12


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  RATE LIMITING
#
#  Applied per source IP at the API layer.
#  Requires REDIS_URL once traffic exceeds a single worker process
#  (in-memory counters do not share state across workers).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

RATE_LIMIT_ENABLED=true

# Maximum requests per IP within the window.
# Reduce to 30–50 in production for public-facing endpoints.
# ← CHANGE FOR PRODUCTION
RATE_LIMIT_REQUESTS=100

# Sliding window duration in seconds.
RATE_LIMIT_WINDOW_SECONDS=60


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FRED API  (St. Louis Fed — SOFR, FX, macro series)
#
#  Used by the SOFR forecasting engine to load historical rate data from FRED.
#  Register a free API key at: https://fred.stlouisfed.org/docs/api/api_key.html
#  Free tier: 120 requests/min, up to 50 series per request.
#
#  Without FRED_API_KEY the SOFR forecast endpoints return HTTP 503.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ← REQUIRED for SOFR forecasting endpoints (/api/v1/forecast/sofr/*)
FRED_API_KEY=your_fred_api_key_here

# FRED REST API base URL — do not change unless using a FRED mirror.
FRED_BASE_URL=https://api.stlouisfed.org/fred

# HTTP request timeout for FRED calls in seconds.
FRED_REQUEST_TIMEOUT_SECONDS=30


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MARKET DATA INTEGRATIONS
#
#  Required when ENABLE_LIVE_FEEDS=true.
#  Leave empty until a live data vendor is contracted.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API key for the configured market-data vendor.
# ← REQUIRED when ENABLE_LIVE_FEEDS=true
MARKET_DATA_API_KEY=

# Base URL for the market-data vendor REST API.
# ← REQUIRED when ENABLE_LIVE_FEEDS=true
MARKET_DATA_BASE_URL=

# HTTP request timeout for market-data calls in seconds.
# Increase for vendors with high P99 latency on historical queries.
MARKET_DATA_TIMEOUT_SECONDS=10


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FEATURE FLAGS
#
#  All flags default to false.  Enable incrementally as each engine is
#  implemented and validated.  The API returns 503 for disabled features
#  rather than 404 so clients can distinguish "not yet" from "not found".
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enables Monte Carlo simulation engine (app/simulations/).
# POST /simulations/ with type=monte_carlo returns 503 when false.
ENABLE_MONTE_CARLO=false

# Enables real-time market data feed connections.
# Requires MARKET_DATA_API_KEY and MARKET_DATA_BASE_URL to be set.
ENABLE_LIVE_FEEDS=false

# Enables ML-based forecasting engine (app/forecasting/).
# All /forecasting/* endpoints return 503 when false.
ENABLE_ML_FORECASTING=false


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  OBSERVABILITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Minimum log severity to emit.
# Accepted: DEBUG | INFO | WARNING | ERROR
# Development: DEBUG or INFO  |  Production: INFO or WARNING
LOG_LEVEL=INFO

# Force structured JSON log output regardless of APP_ENV.
# Auto-enabled on Railway and in production — set true for staging
# when feeding logs into a log aggregator (Datadog, Papertrail, etc.).
LOG_JSON=false

# Sentry error tracking DSN.
# Obtain from your Sentry project's Settings → Client Keys.
# Leave commented to disable error reporting.
#
# SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/your-project-id


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  RAILWAY PLATFORM VARIABLES
#
#  These are injected automatically by Railway at deploy time.
#  Do not set them manually — they are listed here for documentation only.
#  The app reads them to detect the Railway environment and enable JSON logging.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Injected automatically — do not set:
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=baml-risk-backend
# RAILWAY_DEPLOYMENT_ID=<uuid>
# PORT=<assigned-port>
# DATABASE_URL=postgresql://...  (when a Railway PostgreSQL plugin is attached)


# ══════════════════════════════════════════════════════════════════════════════
#  PRODUCTION CHECKLIST
#  Run through this before every production deploy.
# ══════════════════════════════════════════════════════════════════════════════
#
#  [ ] APP_ENV=production
#  [ ] DEBUG=false
#  [ ] SECRET_KEY  is a cryptographically random string ≥ 32 characters
#        python -c "import secrets; print(secrets.token_hex(32))"
#  [ ] POSTGRES_PASSWORD  is strong and unique to this environment
#  [ ] DATABASE_URL  is set (Railway) OR all POSTGRES_* variables are set
#  [ ] ALLOWED_ORIGINS  lists only your actual front-end domain(s)
#  [ ] ALLOWED_HOSTS  lists only your actual API hostname(s) — no wildcard
#  [ ] BCRYPT_ROUNDS=13  (OWASP 2023 minimum for production)
#  [ ] LOG_JSON=true  (or let Railway auto-enable it)
#  [ ] RATE_LIMIT_REQUESTS  reduced to ≤50 for public-facing endpoints
#  [ ] DB_ECHO=false
#  [ ] SENTRY_DSN  is set for error tracking
#  [ ] MARKET_DATA_API_KEY  is set if ENABLE_LIVE_FEEDS=true
#  [ ] Feature flags reviewed — only enable what is deployed and tested
#
#  ENVIRONMENT-SPECIFIC REFERENCE
#  ─────────────────────────────────────────────────────────────────────────────
#  Variable                  │ Development      │ Staging          │ Production
#  ──────────────────────────┼──────────────────┼──────────────────┼────────────
#  APP_ENV                   │ development      │ staging          │ production
#  DEBUG                     │ true             │ false            │ false
#  SECRET_KEY                │ any string       │ random ≥32 chars │ random ≥32c
#  BCRYPT_ROUNDS             │ 10               │ 12               │ 13
#  ALLOWED_HOSTS             │ *                │ staging.host.com │ api.host.com
#  LOG_JSON                  │ false            │ true             │ true (auto)
#  DB_POOL_SIZE              │ 3–5              │ 5–10             │ 10–20
#  RATE_LIMIT_REQUESTS       │ 1000             │ 100              │ 30–50
# ══════════════════════════════════════════════════════════════════════════════
